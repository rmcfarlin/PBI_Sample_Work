{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/visualContainer/2.10.0/schema.json",
  "name": "power-scatter",
  "position": {
    "x": 652,
    "y": 176,
    "z": 0,
    "height": 300,
    "width": 604,
    "tabOrder": 0
  },
  "visual": {
    "visualType": "scatterChart",
    "query": {
      "queryState": {
        "Category": {
          "projections": [
            {
              "field": {
                "Column": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "Hitting"
                    }
                  },
                  "Property": "PlayerName"
                }
              },
              "queryRef": "Hitting.PlayerName",
              "nativeQueryRef": "PlayerName",
              "active": true
            }
          ]
        },
        "X": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "HR"
                }
              },
              "queryRef": "_Measures.HR",
              "nativeQueryRef": "HR"
            }
          ]
        },
        "Y": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "OPS"
                }
              },
              "queryRef": "_Measures.OPS",
              "nativeQueryRef": "OPS"
            }
          ]
        },
        "Size": {
          "projections": [
            {
              "field": {
                "Measure": {
                  "Expression": {
                    "SourceRef": {
                      "Entity": "_Measures"
                    }
                  },
                  "Property": "Hits"
                }
              },
              "queryRef": "_Measures.Hits",
              "nativeQueryRef": "Hits"
            }
          ]
        }
      }
    },
    "visualContainerObjects": {
      "title": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "true"
                }
              }
            },
            "text": {
              "expr": {
                "Literal": {
                  "Value": "'POWER vs PRODUCTION \u2014 HR (x) \u00d7 OPS (y), sized by hits'"
                }
              }
            }
          }
        }
      ],
      "subTitle": [
        {
          "properties": {
            "show": {
              "expr": {
                "Literal": {
                  "Value": "false"
                }
              }
            }
          }
        }
      ]
    },
    "drillFilterOtherVisuals": true
  }
}