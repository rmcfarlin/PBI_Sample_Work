	/// Six-stat percentile ranks vs the full field (>=90th turns crimson) with a clear empty state.
	measure 'Percentile Panel SVG' =
			VAR _n = COUNTROWS(ALL(baseball_hits))
			VAR _has = HASONEVALUE(baseball_hits[PLAYER])
			VAR _c0 = MAX(baseball_hits[H])
			VAR _p0 = ROUND(DIVIDE(COUNTROWS(FILTER(ALL(baseball_hits), baseball_hits[H] < _c0)), _n - 1) * 100, 0)
			VAR _o0 = _p0 & SWITCH(TRUE(), _p0 >= 10 && _p0 <= 20, "th", MOD(_p0,10)=1, "st", MOD(_p0,10)=2, "nd", MOD(_p0,10)=3, "rd", "th")
			VAR _c1 = MAX(baseball_hits[HR])
			VAR _p1 = ROUND(DIVIDE(COUNTROWS(FILTER(ALL(baseball_hits), baseball_hits[HR] < _c1)), _n - 1) * 100, 0)
			VAR _o1 = _p1 & SWITCH(TRUE(), _p1 >= 10 && _p1 <= 20, "th", MOD(_p1,10)=1, "st", MOD(_p1,10)=2, "nd", MOD(_p1,10)=3, "rd", "th")
			VAR _c2 = MAX(baseball_hits[RBI])
			VAR _p2 = ROUND(DIVIDE(COUNTROWS(FILTER(ALL(baseball_hits), baseball_hits[RBI] < _c2)), _n - 1) * 100, 0)
			VAR _o2 = _p2 & SWITCH(TRUE(), _p2 >= 10 && _p2 <= 20, "th", MOD(_p2,10)=1, "st", MOD(_p2,10)=2, "nd", MOD(_p2,10)=3, "rd", "th")
			VAR _c3 = MAX(baseball_hits[Player OPS])
			VAR _p3 = ROUND(DIVIDE(COUNTROWS(FILTER(ALL(baseball_hits), baseball_hits[Player OPS] < _c3)), _n - 1) * 100, 0)
			VAR _o3 = _p3 & SWITCH(TRUE(), _p3 >= 10 && _p3 <= 20, "th", MOD(_p3,10)=1, "st", MOD(_p3,10)=2, "nd", MOD(_p3,10)=3, "rd", "th")
			VAR _c4 = MAX(baseball_hits[Player ISO])
			VAR _p4 = ROUND(DIVIDE(COUNTROWS(FILTER(ALL(baseball_hits), baseball_hits[Player ISO] < _c4)), _n - 1) * 100, 0)
			VAR _o4 = _p4 & SWITCH(TRUE(), _p4 >= 10 && _p4 <= 20, "th", MOD(_p4,10)=1, "st", MOD(_p4,10)=2, "nd", MOD(_p4,10)=3, "rd", "th")
			VAR _c5 = MAX(baseball_hits[SB])
			VAR _p5 = ROUND(DIVIDE(COUNTROWS(FILTER(ALL(baseball_hits), baseball_hits[SB] < _c5)), _n - 1) * 100, 0)
			VAR _o5 = _p5 & SWITCH(TRUE(), _p5 >= 10 && _p5 <= 20, "th", MOD(_p5,10)=1, "st", MOD(_p5,10)=2, "nd", MOD(_p5,10)=3, "rd", "th")
			VAR _svg =
			    "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 366 424'><text x='0' y='14' font-family='Oswald, sans-serif' font-weight='700' font-size='13' fill='#0E3386'>PERCENTILE vs FIELD</text><line x1='0' y1='22' x2='366' y2='22' stroke='#EEF2F9' stroke-width='1'/>"
			    & "<text x='0' y='44' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='12' fill='#12141C'>HITS</text>" & "<text x='366' y='44' font-family='Oswald, sans-serif' font-size='12' fill='#4C5363' text-anchor='end'>" & FORMAT(_c0, "#,0") & " &#8226; " & _o0 & "</text>" & "<rect x='0' y='52' rx='5' width='366' height='12' fill='#EEF2F9'/>" & "<rect x='0' y='52' rx='5' width='" & ROUND(_p0/100*366,0) & "' height='12' fill='" & IF(_p0 >= 90, "#CC3433", "#0E3386") & "'/>"
			    & "<text x='0' y='102' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='12' fill='#12141C'>HR</text>" & "<text x='366' y='102' font-family='Oswald, sans-serif' font-size='12' fill='#4C5363' text-anchor='end'>" & FORMAT(_c1, "#,0") & " &#8226; " & _o1 & "</text>" & "<rect x='0' y='110' rx='5' width='366' height='12' fill='#EEF2F9'/>" & "<rect x='0' y='110' rx='5' width='" & ROUND(_p1/100*366,0) & "' height='12' fill='" & IF(_p1 >= 90, "#CC3433", "#0E3386") & "'/>"
			    & "<text x='0' y='160' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='12' fill='#12141C'>RBI</text>" & "<text x='366' y='160' font-family='Oswald, sans-serif' font-size='12' fill='#4C5363' text-anchor='end'>" & FORMAT(_c2, "#,0") & " &#8226; " & _o2 & "</text>" & "<rect x='0' y='168' rx='5' width='366' height='12' fill='#EEF2F9'/>" & "<rect x='0' y='168' rx='5' width='" & ROUND(_p2/100*366,0) & "' height='12' fill='" & IF(_p2 >= 90, "#CC3433", "#0E3386") & "'/>"
			    & "<text x='0' y='218' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='12' fill='#12141C'>OPS</text>" & "<text x='366' y='218' font-family='Oswald, sans-serif' font-size='12' fill='#4C5363' text-anchor='end'>" & FORMAT(_c3, "#.000") & " &#8226; " & _o3 & "</text>" & "<rect x='0' y='226' rx='5' width='366' height='12' fill='#EEF2F9'/>" & "<rect x='0' y='226' rx='5' width='" & ROUND(_p3/100*366,0) & "' height='12' fill='" & IF(_p3 >= 90, "#CC3433", "#0E3386") & "'/>"
			    & "<text x='0' y='276' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='12' fill='#12141C'>ISO</text>" & "<text x='366' y='276' font-family='Oswald, sans-serif' font-size='12' fill='#4C5363' text-anchor='end'>" & FORMAT(_c4, "#.000") & " &#8226; " & _o4 & "</text>" & "<rect x='0' y='284' rx='5' width='366' height='12' fill='#EEF2F9'/>" & "<rect x='0' y='284' rx='5' width='" & ROUND(_p4/100*366,0) & "' height='12' fill='" & IF(_p4 >= 90, "#CC3433", "#0E3386") & "'/>"
			    & "<text x='0' y='334' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='12' fill='#12141C'>SB</text>" & "<text x='366' y='334' font-family='Oswald, sans-serif' font-size='12' fill='#4C5363' text-anchor='end'>" & FORMAT(_c5, "#,0") & " &#8226; " & _o5 & "</text>" & "<rect x='0' y='342' rx='5' width='366' height='12' fill='#EEF2F9'/>" & "<rect x='0' y='342' rx='5' width='" & ROUND(_p5/100*366,0) & "' height='12' fill='" & IF(_p5 >= 90, "#CC3433", "#0E3386") & "'/>"
			    & "</svg>"
			VAR _empty = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 366 424'><text x='0' y='14' font-family='Oswald, sans-serif' font-weight='700' font-size='13' fill='#0E3386'>PERCENTILE vs FIELD</text><line x1='0' y1='22' x2='366' y2='22' stroke='#EEF2F9' stroke-width='1'/><g transform='translate(143,150)'><rect x='0' y='8' rx='2' width='40' height='6' fill='#EEF2F9'/><rect x='0' y='20' rx='2' width='26' height='6' fill='#EEF2F9'/><rect x='0' y='32' rx='2' width='33' height='6' fill='#EEF2F9'/></g><text x='183' y='235' font-family='Oswald, sans-serif' font-weight='700' font-size='15' fill='#D6DEEE' text-anchor='middle'>SELECT A PLAYER</text><text x='183' y='256' font-family='Libre Franklin, sans-serif' font-size='11' fill='#9AA1B0' text-anchor='middle'>to see how they rank across six stats</text></svg>"
			RETURN IF(_has, _svg, _empty)
		displayFolder: 10 Visuals (SVG)
		lineageTag: 52b41817-10b7-430a-82df-d9d239806192
		dataCategory: ImageUrl

	column Value
		isHidden
		lineageTag: cbf06534-594f-456b-bebf-65fa81d21165
		isNameInferred
		sourceColumn: [Value]

	partition _Measures = calculated
		mode: import
		source = {1}

