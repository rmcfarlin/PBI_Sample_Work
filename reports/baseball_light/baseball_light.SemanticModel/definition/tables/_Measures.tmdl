		dataCategory: ImageUrl

	/// KPI tile (500-HR CLUB) — icon, big value and accent rule in one image.
	measure 'KPI Tile 500HR SVG' = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 244 112'><rect x='1' y='1' width='242' height='110' rx='8' fill='#FFFFFF' stroke='#DCDFE6'/><rect x='14' y='1' width='216' height='4' rx='2' fill='#CC3433'/><circle cx='38' cy='62' r='22' fill='#EEF2F9'/><g transform='translate(38,62)'><path d='M-9 7 Q-2 -11 11 -7' fill='none' stroke='#0E3386' stroke-width='1.3' stroke-dasharray='2.5,2.5'/><circle cx='-9' cy='7' r='3.5' fill='#FFFFFF' stroke='#0E3386' stroke-width='1.3'/></g><text x='72' y='58' font-family='Oswald,sans-serif' font-weight='700' font-size='34' fill='#0E3386'>" & FORMAT([500 HR Club Count], "#,0") & "</text><text x='72' y='84' font-family='Libre Franklin,sans-serif' font-weight='600' font-size='11' fill='#6C7484' letter-spacing='0.5'>500-HR CLUB</text></svg>"
		displayFolder: 10 Visuals (SVG)
		lineageTag: d4a7af4d-a984-4b26-90cd-a644418eef15
		dataCategory: ImageUrl

	/// Hero strip: player name, gold HOF badge, archetype pill, and a one-line career summary. Empty-state prompt when no player is selected.
	measure 'Profile Hero SVG' =
			VAR _p = SELECTEDVALUE(baseball_hits[PLAYER])
			VAR _isHof = MAX(baseball_hits[HOF]) >= 1
			VAR _arch = SELECTEDVALUE(baseball_hits[Archetype])
			VAR _c = SWITCH(_arch, "Slugger", "#CC3433", "Five-Tool", "#0E3386", "Pure Hitter", "#4A69A8", "Table-Setter", "#3C7A3F", "#4C5363")
			VAR _pillw = 16 + LEN(_arch) * 9.6
			VAR _nx = IF(_isHof, 30, 0)
			VAR _badge = IF(_isHof, "<g transform='translate(0,3) scale(0.95)'><circle cx='12' cy='12' r='11' fill='#C8A24B'/><path d='M12 4 L14.2 9.2 L19.8 9.7 L15.5 13.4 L16.9 19 L12 15.9 L7.1 19 L8.5 13.4 L4.2 9.7 L9.8 9.2 Z' fill='#FFFFFF'/></g>", "")
			VAR _narr = FORMAT([Total Seasons], "0") & " seasons" & "  &#8226;  " & FORMAT([Total Hits], "#,0") & " H" & "  &#8226;  " & FORMAT([Total Home Runs], "#,0") & " HR" & "  &#8226;  " & FORMAT([Total RBI], "#,0") & " RBI" & "  &#8226;  " & FORMAT([Batting Average], "#.000") & " AVG" & "  &#8226;  " & FORMAT([OPS (approx)], "#.000") & " OPS"
			VAR _svg = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 980 86'>" & _badge
			    & "<text x='" & _nx & "' y='30' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='#0E3386'>" & UPPER(_p) & "</text>"
			    & "<g transform='translate(" & _nx & ",44)'><rect x='0' y='0' rx='12' width='" & _pillw & "' height='24' fill='" & _c & "'/><text x='" & _pillw / 2 & "' y='16.5' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='12' fill='#FFFFFF' text-anchor='middle'>" & UPPER(_arch) & "</text></g>"
			    & "<text x='980' y='30' font-family='Libre Franklin, sans-serif' font-size='13' fill='#4C5363' text-anchor='end'>" & _narr & "</text></svg>"
			VAR _empty = "data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 980 86'><path d='M40 43 L20 43 M28 35 L18 43 L28 51' fill='none' stroke='#CC3433' stroke-width='3' stroke-linecap='round' stroke-linejoin='round'/><text x='60' y='38' font-family='Oswald, sans-serif' font-weight='700' font-size='26' fill='#D6DEEE'>SELECT A PLAYER</text><text x='60' y='62' font-family='Libre Franklin, sans-serif' font-size='13' fill='#9AA1B0'>Choose a name from the list on the left to load a full career profile.</text></svg>"
			RETURN IF(HASONEVALUE(baseball_hits[PLAYER]), _svg, _empty)
		displayFolder: 10 Visuals (SVG)
		lineageTag: 0d7a4d57-56cf-4004-935c-e6bf75538431
		dataCategory: ImageUrl

	/// Twelve career counting totals in a clean grid (G..CS). Shows dashes when no player is selected.
	measure 'Career Totals Panel SVG' =
			VAR _has = HASONEVALUE(baseball_hits[PLAYER])
			VAR _ct0 = IF(_has, FORMAT([Total Games], "#,0"), "&#8212;")
			VAR _ct1 = IF(_has, FORMAT([Total At-Bats], "#,0"), "&#8212;")
			VAR _ct2 = IF(_has, FORMAT([Total Runs], "#,0"), "&#8212;")
			VAR _ct3 = IF(_has, FORMAT([Total Hits], "#,0"), "&#8212;")
			VAR _ct4 = IF(_has, FORMAT([Total Doubles], "#,0"), "&#8212;")
			VAR _ct5 = IF(_has, FORMAT([Total Triples], "#,0"), "&#8212;")
			VAR _ct6 = IF(_has, FORMAT([Total Home Runs], "#,0"), "&#8212;")
			VAR _ct7 = IF(_has, FORMAT([Total RBI], "#,0"), "&#8212;")
			VAR _ct8 = IF(_has, FORMAT([Total Walks], "#,0"), "&#8212;")
			VAR _ct9 = IF(_has, FORMAT([Total Strikeouts], "#,0"), "&#8212;")
			VAR _ct10 = IF(_has, FORMAT([Total Stolen Bases], "#,0"), "&#8212;")
			VAR _ct11 = IF(_has, FORMAT([Total Caught Stealing], "#,0"), "&#8212;")
			RETURN
			"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 980 150'><text x='0' y='14' font-family='Oswald, sans-serif' font-weight='700' font-size='13' fill='#0E3386'>CAREER TOTALS</text><line x1='0' y1='22' x2='980' y2='22' stroke='#EEF2F9' stroke-width='1'/>"
			    & "<text x='81' y='44' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct0 & "</text><text x='81' y='62' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>G</text>"
			    & "<text x='245' y='44' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct1 & "</text><text x='245' y='62' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>AB</text>"
			    & "<text x='408' y='44' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct2 & "</text><text x='408' y='62' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>R</text>"
			    & "<text x='571' y='44' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct3 & "</text><text x='571' y='62' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>H</text>"
			    & "<text x='735' y='44' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct4 & "</text><text x='735' y='62' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>2B</text>"
			    & "<text x='898' y='44' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct5 & "</text><text x='898' y='62' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>3B</text>"
			    & "<text x='81' y='102' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct6 & "</text><text x='81' y='120' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>HR</text>"
			    & "<text x='245' y='102' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct7 & "</text><text x='245' y='120' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>RBI</text>"
			    & "<text x='408' y='102' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct8 & "</text><text x='408' y='120' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>BB</text>"
			    & "<text x='571' y='102' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct9 & "</text><text x='571' y='120' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>SO</text>"
			    & "<text x='735' y='102' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct10 & "</text><text x='735' y='120' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>SB</text>"
			    & "<text x='898' y='102' font-family='Oswald, sans-serif' font-weight='600' font-size='26' fill='#0E3386' text-anchor='middle'>" & _ct11 & "</text><text x='898' y='120' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>CS</text>"
			    & "</svg>"
		displayFolder: 10 Visuals (SVG)
		lineageTag: 8e613792-b59d-4497-88c1-d220bb348498
		dataCategory: ImageUrl

	/// Eight rate/value stats as icon tiles (AVG, OBP, SLG, OPS, ISO, BB/K, SB%, AB/HR). Dashes when no player is selected.
	measure 'Sabermetrics Panel SVG' =
			VAR _has = HASONEVALUE(baseball_hits[PLAYER])
			VAR _sb0 = IF(_has, FORMAT([Batting Average], "#.000"), "&#8212;")
			VAR _sb1 = IF(_has, FORMAT([On-Base Pct (approx)], "#.000"), "&#8212;")
			VAR _sb2 = IF(_has, FORMAT([Slugging Pct], "#.000"), "&#8212;")
			VAR _sb3 = IF(_has, FORMAT([OPS (approx)], "#.000"), "&#8212;")
			VAR _sb4 = IF(_has, FORMAT([Isolated Power (ISO)], "#.000"), "&#8212;")
			VAR _sb5 = IF(_has, FORMAT([BB per K], "0.00"), "&#8212;")
			VAR _sb6 = IF(_has, FORMAT([SB Success Pct], "0.0%"), "&#8212;")
			VAR _sb7 = IF(_has, FORMAT([AB per HR], "0.0"), "&#8212;")
			RETURN
			"data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 600 424'><text x='0' y='14' font-family='Oswald, sans-serif' font-weight='700' font-size='13' fill='#0E3386'>RATE &amp; VALUE</text>"
			    & "<rect x='0' y='26' rx='10' width='141' height='192' fill='#F7F8FA' stroke='#DCDFE6' stroke-width='1'/><rect x='0' y='26' rx='10' width='141' height='4' fill='#0E3386'/><g transform='translate(16,46)' fill='none' stroke='#0E3386' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><circle cx='10' cy='10' r='8' stroke='#0E3386'/><path d='M5 4 A 8 8 0 0 0 5 16' stroke='#CC3433'/><path d='M15 4 A 8 8 0 0 1 15 16' stroke='#CC3433'/></g>" & "<text x='70' y='136' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='" & IF(_has,"#0E3386","#9AA1B0") & "' text-anchor='middle'>" & _sb0 & "</text>" & "<text x='70' y='204' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>BATTING AVG</text>"
			    & "<rect x='153' y='26' rx='10' width='141' height='192' fill='#F7F8FA' stroke='#DCDFE6' stroke-width='1'/><rect x='153' y='26' rx='10' width='141' height='4' fill='#0E3386'/><g transform='translate(169,46)' fill='none' stroke='#0E3386' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><path d='M10 3 L17 9 L10 17 L3 9 Z' stroke='#0E3386'/><circle cx='10' cy='10' r='1.6' fill='#0E3386' stroke='none'/></g>" & "<text x='223' y='136' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='" & IF(_has,"#0E3386","#9AA1B0") & "' text-anchor='middle'>" & _sb1 & "</text>" & "<text x='223' y='204' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>ON-BASE %</text>"
			    & "<rect x='306' y='26' rx='10' width='141' height='192' fill='#F7F8FA' stroke='#DCDFE6' stroke-width='1'/><rect x='306' y='26' rx='10' width='141' height='4' fill='#0E3386'/><g transform='translate(322,46)' fill='none' stroke='#0E3386' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><rect x='3' y='12' width='3.4' height='5' rx='1' fill='#0E3386' stroke='none'/><rect x='8.3' y='8' width='3.4' height='9' rx='1' fill='#0E3386' stroke='none'/><rect x='13.6' y='4' width='3.4' height='13' rx='1' fill='#0E3386' stroke='none'/></g>" & "<text x='376' y='136' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='" & IF(_has,"#0E3386","#9AA1B0") & "' text-anchor='middle'>" & _sb2 & "</text>" & "<text x='376' y='204' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>SLUGGING %</text>"
			    & "<rect x='459' y='26' rx='10' width='141' height='192' fill='#F7F8FA' stroke='#DCDFE6' stroke-width='1'/><rect x='459' y='26' rx='10' width='141' height='4' fill='#0E3386'/><g transform='translate(475,46)' fill='none' stroke='#0E3386' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><path d='M10 2 L12.4 7.6 L18.5 8.1 L13.8 12 L15.3 18 L10 14.7 L4.7 18 L6.2 12 L1.5 8.1 L7.6 7.6 Z' fill='#0E3386' stroke='none'/></g>" & "<text x='529' y='136' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='" & IF(_has,"#0E3386","#9AA1B0") & "' text-anchor='middle'>" & _sb3 & "</text>" & "<text x='529' y='204' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>OPS</text>"
			    & "<rect x='0' y='232' rx='10' width='141' height='192' fill='#F7F8FA' stroke='#DCDFE6' stroke-width='1'/><rect x='0' y='232' rx='10' width='141' height='4' fill='#CC3433'/><g transform='translate(16,252)' fill='none' stroke='#CC3433' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><path d='M3 15 Q 10 1 17 8' stroke='#CC3433'/><circle cx='17' cy='8' r='2.4' fill='#CC3433' stroke='none'/></g>" & "<text x='70' y='342' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='" & IF(_has,"#0E3386","#9AA1B0") & "' text-anchor='middle'>" & _sb4 & "</text>" & "<text x='70' y='410' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>ISO</text>"
			    & "<rect x='153' y='232' rx='10' width='141' height='192' fill='#F7F8FA' stroke='#DCDFE6' stroke-width='1'/><rect x='153' y='232' rx='10' width='141' height='4' fill='#4A69A8'/><g transform='translate(169,252)' fill='none' stroke='#4A69A8' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><path d='M10 3 V 16' stroke='#4A69A8'/><path d='M4 6 H 16' stroke='#4A69A8'/><path d='M4 6 L2 11 H6 Z' fill='#4A69A8' stroke='none'/><path d='M16 6 L14 11 H18 Z' fill='#4A69A8' stroke='none'/><path d='M7 17 H 13' stroke='#4A69A8'/></g>" & "<text x='223' y='342' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='" & IF(_has,"#0E3386","#9AA1B0") & "' text-anchor='middle'>" & _sb5 & "</text>" & "<text x='223' y='410' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>BB / K</text>"
			    & "<rect x='306' y='232' rx='10' width='141' height='192' fill='#F7F8FA' stroke='#DCDFE6' stroke-width='1'/><rect x='306' y='232' rx='10' width='141' height='4' fill='#3C7A3F'/><g transform='translate(322,252)' fill='none' stroke='#3C7A3F' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><path d='M4 6 L9 10 L4 14' stroke='#3C7A3F'/><path d='M10 6 L15 10 L10 14' stroke='#3C7A3F'/></g>" & "<text x='376' y='342' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='" & IF(_has,"#0E3386","#9AA1B0") & "' text-anchor='middle'>" & _sb6 & "</text>" & "<text x='376' y='410' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>SB SUCCESS</text>"
			    & "<rect x='459' y='232' rx='10' width='141' height='192' fill='#F7F8FA' stroke='#DCDFE6' stroke-width='1'/><rect x='459' y='232' rx='10' width='141' height='4' fill='#CC3433'/><g transform='translate(475,252)' fill='none' stroke='#CC3433' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round'><circle cx='10' cy='10' r='8' stroke='#CC3433'/><circle cx='10' cy='10' r='4' stroke='#CC3433'/><circle cx='10' cy='10' r='1' fill='#CC3433' stroke='none'/></g>" & "<text x='529' y='342' font-family='Oswald, sans-serif' font-weight='700' font-size='30' fill='" & IF(_has,"#0E3386","#9AA1B0") & "' text-anchor='middle'>" & _sb7 & "</text>" & "<text x='529' y='410' font-family='Libre Franklin, sans-serif' font-weight='600' font-size='11' fill='#4C5363' text-anchor='middle'>AB / HR</text>"
			    & "</svg>"
